{
  // ink-board dashboard configuration
  // Format: JSON5 (comments and trailing commas are allowed)

  device: {
    // URL of the ink-board device (no trailing slash)
    url: "http://192.168.1.x",

    // Directory where data-source programs drop their *.json / *.txt files
    data_dir: "/home/user/.local/share/ink-board/data",

    // Path to the layout JSON5 file, relative to this config file
    layout: "layouts/dashboard.example.layout.json5",
  },

  // Each entry defines one data source and how to extract a value from it.
  // The `id` becomes the key referenced as {id} in the layout's text widgets.
  sources: [

    {
      id: "btc",
      file: "btc.json",
      key: "price",
      max_age: 300,
      stale_placeholder: "—",
    },

    {
      id: "weather",
      file: "weather.json",
      key: "temp_c",
      max_age: 1800,
      stale_placeholder: "—",
    },

    {
      id: "power",
      file: "power.txt",
      max_age: 60,
      stale_placeholder: "—",
    },

    {
      id: "clock",
      file: "clock.txt",
      max_age: 120,
      stale_placeholder: "--:--",
    },

  ],
}
