{
  // ink-board dashboard configuration
  // Format: JSON5 (comments and trailing commas are allowed)
  // Reference: https://json5.org/

  device: {
    // URL of the ink-board device (no trailing slash)
    url: "http://192.168.1.x",

    // Directory where data-source programs drop their *.json / *.txt files
    data_dir: "/home/user/.local/share/ink-board/data",

    // Path to the EJS HTML template, relative to this config file
    template: "templates/dashboard.example.html.ejs",
  },

  // Each entry defines one data source and how to extract a value from it.
  // The `id` becomes the key in the EJS template's `data` object.
  sources: [

    {
      id: "btc",            // accessed as data.btc in the template
      file: "btc.json",     // file in data_dir
      key: "price",         // dot-path into the JSON (e.g. "current.usd")
      max_age: 300,         // seconds — treat as stale after 5 minutes
      stale_placeholder: "—",
    },

    {
      id: "weather",
      file: "weather.json",
      key: "temp_c",        // e.g. { "temp_c": "12°C", "desc": "Cloudy" }
      max_age: 1800,        // 30 minutes — weather doesn't change that fast
      stale_placeholder: "—",
    },

    {
      id: "power",
      file: "power.txt",    // plain-text: first line is the value, e.g. "2.4"
      // key: omit for .txt files — the whole first line is used
      max_age: 60,          // 1 minute — should update frequently
      stale_placeholder: "—",
    },

    {
      id: "clock",
      file: "clock.txt",    // a cron job writes current time: echo "14:30" > clock.txt
      max_age: 120,
      stale_placeholder: "--:--",
    },

  ],
}
